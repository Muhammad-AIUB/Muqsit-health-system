// Prisma schema — Muqsit backend (Neon Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String

  // role: "admin" for back-office users, "professional" for healthcare sign-ups.
  role String @default("professional")

  // ── Healthcare professional registration ──────────────────
  mobile       String? // exactly 11 digits
  profession   String? // doctor | intern_doctor | nurse | medical_technologist | computer_operator
  registrationNo String? // BMDC / temporary / professional reg no (null for computer_operator)
  nidNo        String?
  designation  String?
  specialty    String?
  institutionCode String? // hospital / institution code (optional)

  // Uploaded document URLs (Cloudinary)
  profilePictureUrl   String?
  registrationCertUrl String?
  nidFrontUrl         String?
  nidBackUrl          String?
  // Free-form extra certificates the user uploads from their profile page.
  // Each certificate is an image URL with an optional details note —
  // stored as a relation so the pair stays linked even when reordered.
  otherCertificates OtherCertificate[]

  // ── Verification & approval lifecycle ─────────────────────
  emailVerified   Boolean @default(false)
  approvalStatus  String  @default("pending") // pending | approved | suspended | rejected
  rejectionReason String?
  accountTier     String  @default("secondary") // secondary (new sign-ups) | primary (admin-promoted)

  patients      Patient[]
  prescriptions Prescription[]

  // RBAC: assistants this user (as a doctor) manages, and the links where
  // this user is itself someone's assistant.
  assistants   Assistant[] @relation("DoctorAssistants")
  assistingFor Assistant[] @relation("AssistantLinks")

  // Default permission keys applied to every new assistant this doctor adds,
  // and used to pre-fill the per-assistant permission editor.
  assistantDefaultPermissions String[] @default([])

  refreshTokens RefreshToken[]

  // Practice locations (chambers / clinics) — multiple per doctor.
  chambers Chamber[]

  // Prescription print layout (page size, header, footer) — one per doctor.
  prescriptionLayout PrescriptionLayout?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([approvalStatus])
}

// Additional qualification / certificate uploaded from the profile page.
// `details` is a free-form note ("MD Cardiology, BSMMU 2019" etc.).
model OtherCertificate {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  url     String
  details String?
  order   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Practice location for a doctor. Free-form address + an optional map URL
// the doctor can share with patients. Order is preserved in the UI.
model Chamber {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address String
  mapLink String?
  order   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Print layout for a doctor's prescription pad — page size + margins, and the
// rich-text header/footer. One row per doctor (configured in Settings →
// Prescription settings). Numbers kept as strings to mirror the form inputs.
model PrescriptionLayout {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Page setup
  unit         String @default("in") // in | cm
  totalHeight  String @default("11")
  totalWidth   String @default("8.25")
  leftMargin   String @default("0.3")
  rightMargin  String @default("0.2")
  headerHeight String @default("1.7")
  footerHeight String @default("0.8")

  // Header (single block aligned, or split into two sections)
  headerSplit     Boolean @default(false)
  headerAlign     String  @default("left") // left | center | right
  headerHtml      String  @default("")
  headerLeftHtml  String  @default("")
  headerRightHtml String  @default("")

  // Footer
  footerHtml String @default("")

  // Body section — two columns split by a separator at `bodySplit` (in the
  // page unit; "" = auto/centre), with independent top margins and an optional
  // bottom line.
  bodySplit          String  @default("")
  bodyLeftTopMargin  String  @default("0")
  bodyRightTopMargin String  @default("0")
  bodyBottomLine     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Opaque refresh tokens, stored as SHA-256 hashes. Every login starts a new
// "family"; rotation issues a new token in the same family and revokes the
// previous one. If a revoked token is ever presented again we assume theft
// and revoke the entire family at once.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  family    String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([family])
}

// ── Assistants & RBAC ────────────────────────────────────────
// Links a doctor to another registered user who assists them, with a
// per-assistant set of section-level edit permissions. Sensitive — lives
// only server-side, never in the browser.
model Assistant {
  id String @id @default(cuid())

  doctorId String
  doctor   User   @relation("DoctorAssistants", fields: [doctorId], references: [id], onDelete: Cascade)

  assistantId String
  assistant   User   @relation("AssistantLinks", fields: [assistantId], references: [id], onDelete: Cascade)

  // Granted permission keys (e.g. "rx.drugHistory", "pt.info").
  permissions String[] @default([])
  status      String   @default("active") // active | suspended

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, assistantId])
  @@index([doctorId])
  @@index([assistantId])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Patient {
  id               String    @id @default(cuid())
  name             String
  hospitalId       String?
  bloodGroup       String?
  dob              DateTime?
  age              Int?
  sex              String?
  ethnicity        String?
  religion         String?
  mobile           String?
  spouseMobile     String?
  relativeMobile   String?
  relativeRelation String?
  district         String?
  fullAddress      String?
  monthlyIncome    String?
  pictureUrl       String?
  tags             String[]  @default([])
  watched          Boolean   @default(false) // "Keep eye on this patient"

  doctorId String?
  doctor   User?   @relation(fields: [doctorId], references: [id], onDelete: SetNull)

  prescriptions Prescription[]
  opdVisits     OpdVisit[]
  ipdAdmissions IpdAdmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([name])
}

// ── OPD queue ────────────────────────────────────────────────
model OpdVisit {
  id        String   @id @default(cuid())
  doctorId  String
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  // Snapshot fields so the queue row survives even without a saved patient.
  name   String
  phone  String?
  age    Int?
  gender String?

  type   String @default("New") // New | Follow-up | Urgent
  token  String
  status String @default("waiting") // waiting | done

  createdAt DateTime @default(now())

  @@index([doctorId, createdAt])
}

// ── IPD ward ─────────────────────────────────────────────────
model IpdAdmission {
  id        String   @id @default(cuid())
  doctorId  String
  patientId String?
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  bed           String
  name          String
  hospitalId    String?
  roomNo        String?
  wardNo        String? // cabin / ward no
  floorBuilding String? // floor or building
  mobile        String?
  diagnosis     String?
  status        String  @default("Stable") // Stable | Observation | Critical | Discharge

  events IpdEvent[]

  admittedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([doctorId])
}

model IpdEvent {
  id          String       @id @default(cuid())
  admissionId String
  admission   IpdAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  author    String
  role      String?
  note      String
  reportUrl String?

  createdAt DateTime @default(now())

  @@index([admissionId, createdAt])
}

model Prescription {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  // Clinical assessment (left column of the prescription)
  chiefComplaints      String[] @default([])
  history              String[] @default([])
  investigation        String[] @default([])
  drugHistory          String[] @default([])
  onExamination        String[] @default([])
  note                 String[] @default([])
  provisionalDiagnosis String[] @default([])
  associatedIllness    String[] @default([])
  finalDiagnosis       String[] @default([])

  // Right column extras
  advice     String[] @default([])
  adviceTest String[] @default([])

  followUpNum       String?
  followUpUnit      String?
  followUpMandatory Boolean @default(false)

  items PrescriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug           String
  dose           String
  duration       String
  instruction    String
  order          Int          @default(0)
}
