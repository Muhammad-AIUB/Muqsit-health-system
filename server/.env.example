# Neon Postgres (pooled — used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
# Direct connection (no pooler) — used by Prisma migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Auth
# JWT_SECRET MUST be a long random string in production. The server refuses to
# start in production if this is missing, equal to "dev-secret", or under 32
# chars. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="replace-with-a-long-random-string"
# Short-lived access token. Lives in an httpOnly cookie (mhs_at).
JWT_EXPIRES_IN="15m"
# Refresh token lifetime in days. Lives in an httpOnly cookie (mhs_rt) scoped
# to /api/auth. Rotated on every use; reuse of a revoked token kills the
# whole session family.
REFRESH_EXPIRES_DAYS=30
# Refresh-token lifetime when the user UNCHECKS "Remember me" (hours).
# The cookie is also written without an Expires attribute so the browser
# treats it as a session cookie and drops it on close.
SESSION_EXPIRES_HOURS=12

# Cookie hardening. Set COOKIE_SECURE=true once you're on HTTPS (required
# whenever COOKIE_SAMESITE=none). COOKIE_DOMAIN is only needed if you want
# the cookie to span subdomains (e.g. ".muqsit.com").
COOKIE_SECURE=
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# API
PORT=4000
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Email (OTP verification). For Gmail, use an App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Muqsit Health System <no-reply@muqsit.local>"
OTP_EXPIRES_MIN=10

# File uploads (stored on this server's disk, served at /uploads).
# In production set this to the API's public domain.
PUBLIC_URL="http://localhost:4000"

# First admin user (created by `npm run seed`)
ADMIN_SEED_EMAIL="admin@muqsit.local"
ADMIN_SEED_PASSWORD="change-me"
ADMIN_SEED_NAME="Muqsit Health System Admin"
